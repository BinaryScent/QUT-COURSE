do.sh
# use two star ** to repr any internal dir
.git/**
.self/**
.bigFile/**
/*.zip
!.gitignore
~$*
*.o
*.toc
*.synctex.*
*.log
*.aux
*.pyc
a.out
__pycache__/**
.DS_Store

# Cookie文件（包含敏感信息）
utils/my/cookie.json

# 日志目录
utils/my/logs/

# IDE配置
.idea/

# 临时备份和转换文件
backup-modified/
convert-data.js
data.js.bak
test-data.js

# 根目录临时文件（源文件在web/和docs/目录）
/app.js
/index.html
/style.css
/data.js
/images/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
